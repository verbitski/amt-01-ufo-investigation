{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.amt-01.invalid/v1/case-bundle.schema.json",
  "title": "AMT-01 Open Research case bundle",
  "description": "MVP validation bundle for a case, atomic claims, sources, assets, and reviews.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_status",
    "case",
    "claims",
    "sources",
    "assets",
    "reviews"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "bundle_status": {
      "enum": ["migration_fixture", "proposed", "reviewed_release"]
    },
    "case": {
      "$ref": "#/$defs/case"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/asset"
      }
    },
    "reviews": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/review"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9-]{2,79}$"
    },
    "nullableDate": {
      "type": ["string", "null"],
      "format": "date"
    },
    "stringOrNull": {
      "type": ["string", "null"]
    },
    "quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit"],
      "properties": {
        "value": {"type": "number"},
        "min": {"type": "number"},
        "max": {"type": "number"},
        "unit": {"type": "string", "minLength": 1},
        "unit_system": {"enum": ["SI", "UCUM", "count", "other"]},
        "raw_expression": {"type": "string"}
      },
      "anyOf": [
        {"required": ["value"]},
        {"required": ["min", "max"]}
      ]
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "legacy_ids",
        "title",
        "case_role",
        "resolution_status",
        "migration_status",
        "public_summary",
        "event",
        "observation_modes",
        "observer_groups",
        "evidence_assessment",
        "privacy",
        "claim_ids",
        "source_ids",
        "asset_ids",
        "revision"
      ],
      "properties": {
        "case_id": {"$ref": "#/$defs/id"},
        "legacy_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "title": {"type": "string", "minLength": 1},
        "case_role": {
          "enum": ["project_baseline", "comparative", "negative_control"]
        },
        "resolution_status": {
          "enum": ["unresolved", "identified", "insufficient_data", "disputed"]
        },
        "migration_status": {
          "enum": ["partial_fixture", "complete_unreviewed", "complete_reviewed"]
        },
        "public_summary": {"type": "string", "minLength": 1},
        "event": {
          "type": "object",
          "additionalProperties": false,
          "required": ["time", "location"],
          "properties": {
            "time": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "reported_description",
                "value_status",
                "normalized_start",
                "normalized_end",
                "precision",
                "timezone",
                "unknown_reason"
              ],
              "properties": {
                "reported_description": {"type": "string"},
                "value_status": {"enum": ["reported", "estimated", "unknown", "withheld"]},
                "normalized_start": {"$ref": "#/$defs/nullableDate"},
                "normalized_end": {"$ref": "#/$defs/nullableDate"},
                "precision": {"enum": ["exact", "day", "month", "season", "year", "life_period", "unknown"]},
                "timezone": {"$ref": "#/$defs/stringOrNull"},
                "unknown_reason": {"$ref": "#/$defs/stringOrNull"}
              }
            },
            "location": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "public_description",
                "country_code",
                "value_status",
                "precision",
                "latitude",
                "longitude",
                "unknown_reason"
              ],
              "properties": {
                "public_description": {"type": "string"},
                "country_code": {"type": ["string", "null"], "pattern": "^[A-Z]{2}$"},
                "value_status": {"enum": ["reported", "estimated", "unknown", "withheld"]},
                "precision": {"enum": ["exact", "site", "city", "region", "country", "unknown"]},
                "latitude": {"type": ["number", "null"], "minimum": -90, "maximum": 90},
                "longitude": {"type": ["number", "null"], "minimum": -180, "maximum": 180},
                "unknown_reason": {"$ref": "#/$defs/stringOrNull"}
              }
            }
          }
        },
        "observation_modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["unaided_visual", "unaided_hearing", "human_sensory", "photo", "video", "audio", "instrument", "reported_only"]}
        },
        "observer_groups": {"type": "integer", "minimum": 0},
        "evidence_assessment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tier", "tier_status", "rubric_version", "rationale", "dimensions", "review_ids"],
          "properties": {
            "tier": {"enum": ["A", "B", "C", "D"]},
            "tier_status": {"enum": ["proposed", "reviewed", "disputed"]},
            "rubric_version": {"type": "string"},
            "rationale": {"type": "string"},
            "dimensions": {
              "type": "object",
              "additionalProperties": {"type": ["string", "number", "boolean", "null"]}
            },
            "review_ids": {
              "type": "array",
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/id"}
            }
          }
        },
        "discovery": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "collection_id": {"$ref": "#/$defs/stringOrNull"},
            "query": {"$ref": "#/$defs/stringOrNull"},
            "inclusion_reason": {"$ref": "#/$defs/stringOrNull"},
            "exclusion_log_ref": {"$ref": "#/$defs/stringOrNull"}
          }
        },
        "privacy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contains_personal_data", "raw_record_public", "exact_location_status", "public_location_precision", "consent_record_id"],
          "properties": {
            "contains_personal_data": {"type": "boolean"},
            "raw_record_public": {"type": "boolean"},
            "exact_location_status": {"enum": ["public", "withheld", "unknown"]},
            "public_location_precision": {"enum": ["exact", "site", "city", "region", "country", "none"]},
            "consent_record_id": {"$ref": "#/$defs/stringOrNull"}
          }
        },
        "claim_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/id"}
        },
        "source_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/id"}
        },
        "asset_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/id"}
        },
        "revision": {
          "type": "object",
          "additionalProperties": false,
          "required": ["created_at", "updated_at", "content_version", "schema_version"],
          "properties": {
            "created_at": {"type": "string", "format": "date"},
            "updated_at": {"type": "string", "format": "date"},
            "content_version": {"type": "string"},
            "schema_version": {"type": "string"}
          }
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "case_id",
        "legacy_group_ids",
        "type",
        "statement",
        "normalized",
        "record_confidence",
        "confidence_basis",
        "status",
        "evidence_links",
        "relations"
      ],
      "properties": {
        "claim_id": {"$ref": "#/$defs/id"},
        "case_id": {"$ref": "#/$defs/id"},
        "legacy_group_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "type": {"enum": ["OBS", "EST", "DER", "INF", "HYP", "EXT", "DEC", "UNK"]},
        "statement": {"type": "string", "minLength": 1},
        "normalized": {
          "type": "object",
          "additionalProperties": false,
          "required": ["subject", "property", "value_status"],
          "properties": {
            "subject": {"type": "string"},
            "property": {"type": "string"},
            "value_status": {"enum": ["reported", "estimated", "derived", "not_detected", "unknown", "withheld", "not_applicable"]},
            "value": {"type": ["string", "number", "boolean", "null"]},
            "quantity": {"$ref": "#/$defs/quantity"}
          }
        },
        "record_confidence": {"enum": ["high", "medium", "low", "not_applicable", "unrated"]},
        "confidence_basis": {"type": "string"},
        "status": {"enum": ["proposed", "retained", "disputed", "superseded", "rejected", "deprioritized", "active", "parked", "open"]},
        "evidence_links": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_id", "relation", "locator", "verification"],
            "properties": {
              "source_id": {"$ref": "#/$defs/id"},
              "relation": {"enum": ["asserted_in", "extracted_from", "supports", "contradicts", "illustrates"]},
              "locator": {"type": "string"},
              "verification": {"enum": ["original_checked", "project_record_checked", "transcription_only", "unverified"]}
            }
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["relation", "target_id"],
            "properties": {
              "relation": {"enum": ["derived_from", "supports", "contradicts", "supersedes", "same_event_as", "possibly_same_event_as", "illustrates"]},
              "target_id": {"$ref": "#/$defs/id"}
            }
          }
        },
        "observation_conditions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["observer_mode", "scene_description", "calibrated_threshold", "threshold_unknown_reason"],
          "properties": {
            "observer_mode": {"type": "string"},
            "scene_description": {"type": "string"},
            "calibrated_threshold": {"type": ["number", "null"]},
            "threshold_unit": {"type": ["string", "null"]},
            "threshold_unknown_reason": {"type": ["string", "null"]}
          }
        },
        "estimate_basis": {"type": "string"},
        "derived_from": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/id"}
        },
        "method": {
          "type": "object",
          "additionalProperties": false,
          "required": ["equation", "analysis_id", "implementation_version", "assumptions"],
          "properties": {
            "equation": {"type": "string"},
            "analysis_id": {"$ref": "#/$defs/id"},
            "implementation_version": {"type": ["string", "null"]},
            "assumptions": {"type": "array", "items": {"type": "string"}}
          }
        }
      },
      "allOf": [
        {
          "if": {"properties": {"type": {"enum": ["OBS", "EXT"]}}, "required": ["type"]},
          "then": {"properties": {"evidence_links": {"minItems": 1}}}
        },
        {
          "if": {"properties": {"type": {"const": "EST"}}, "required": ["type"]},
          "then": {"required": ["estimate_basis"]}
        },
        {
          "if": {"properties": {"type": {"const": "DER"}}, "required": ["type"]},
          "then": {"required": ["derived_from", "method"]}
        },
        {
          "if": {
            "properties": {
              "normalized": {
                "properties": {"value_status": {"const": "not_detected"}},
                "required": ["value_status"]
              }
            },
            "required": ["normalized"]
          },
          "then": {"required": ["observation_conditions"]}
        }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "case_ids",
        "source_kind",
        "title",
        "creator_role",
        "publisher",
        "event_date",
        "report_date",
        "url",
        "original_preserved",
        "locators",
        "transformations",
        "verification_status",
        "rights",
        "privacy"
      ],
      "properties": {
        "source_id": {"$ref": "#/$defs/id"},
        "case_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "source_kind": {"enum": ["original_sensor_data", "original_media", "first_person_contemporaneous", "first_person_retrospective", "government_record", "official_summary", "transcription", "secondary_journalism", "social_media", "other"]},
        "title": {"type": "string"},
        "creator_role": {"type": "string"},
        "publisher": {"$ref": "#/$defs/stringOrNull"},
        "event_date": {"$ref": "#/$defs/nullableDate"},
        "report_date": {"$ref": "#/$defs/nullableDate"},
        "url": {"type": ["string", "null"], "format": "uri"},
        "original_preserved": {"type": "boolean"},
        "preserved_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "locators": {"type": "array", "items": {"type": "string"}},
        "transformations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "tool", "model_version", "date", "human_checked"],
            "properties": {
              "kind": {"type": "string"},
              "tool": {"type": "string"},
              "model_version": {"type": ["string", "null"]},
              "date": {"type": "string", "format": "date"},
              "human_checked": {"type": "boolean"}
            }
          }
        },
        "verification_status": {"enum": ["original_checked", "project_record_checked", "transcription_only", "unverified"]},
        "rights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "rights_holder", "license", "redistribution_allowed"],
          "properties": {
            "status": {"enum": ["cleared", "public_domain", "permission_required", "unknown"]},
            "rights_holder": {"$ref": "#/$defs/stringOrNull"},
            "license": {"$ref": "#/$defs/stringOrNull"},
            "redistribution_allowed": {"type": ["boolean", "null"]}
          }
        },
        "privacy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contains_personal_data", "redaction_status"],
          "properties": {
            "contains_personal_data": {"type": "boolean"},
            "redaction_status": {"enum": ["not_needed", "redacted", "review_required", "private"]}
          }
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "case_ids",
        "title",
        "path_or_url",
        "mime_type",
        "sha256",
        "dimensions",
        "created_at",
        "evidentiary_role",
        "synthetic_status",
        "synthetic",
        "generation",
        "parent_asset_ids",
        "rights",
        "redaction_status"
      ],
      "properties": {
        "asset_id": {"$ref": "#/$defs/id"},
        "case_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "title": {"type": "string"},
        "path_or_url": {"type": "string"},
        "mime_type": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "dimensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "width_px": {"type": ["integer", "null"], "minimum": 1},
            "height_px": {"type": ["integer", "null"], "minimum": 1},
            "duration_s": {"type": ["number", "null"], "minimum": 0}
          }
        },
        "created_at": {"$ref": "#/$defs/nullableDate"},
        "evidentiary_role": {"enum": ["primary", "derivative", "illustrative", "reconstruction"]},
        "synthetic_status": {"enum": ["confirmed_synthetic", "confirmed_non_synthetic", "unknown"]},
        "synthetic": {"type": ["boolean", "null"]},
        "generation": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["tool", "model_version", "prompt_ref", "human_reviewed"],
          "properties": {
            "tool": {"type": "string"},
            "model_version": {"type": ["string", "null"]},
            "prompt_ref": {"type": "string"},
            "human_reviewed": {"type": "boolean"}
          }
        },
        "parent_asset_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "rights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "rights_holder", "license", "redistribution_allowed"],
          "properties": {
            "status": {"enum": ["cleared", "public_domain", "permission_required", "unknown"]},
            "rights_holder": {"$ref": "#/$defs/stringOrNull"},
            "license": {"$ref": "#/$defs/stringOrNull"},
            "redistribution_allowed": {"type": ["boolean", "null"]}
          }
        },
        "redaction_status": {"enum": ["not_needed", "redacted", "review_required", "private"]}
      },
      "allOf": [
        {
          "if": {"properties": {"synthetic": {"const": true}}, "required": ["synthetic"]},
          "then": {
            "properties": {
              "evidentiary_role": {"enum": ["illustrative", "reconstruction"]}
            }
          }
        }
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_id", "object_id", "reviewer_id", "stage", "checklist_version", "outcome", "limitations", "conflict_declaration", "date", "commit_hash"],
      "properties": {
        "review_id": {"$ref": "#/$defs/id"},
        "object_id": {"$ref": "#/$defs/id"},
        "reviewer_id": {"type": "string"},
        "stage": {"enum": ["triage", "source_verification", "domain_review", "evidence_assessment", "privacy_review", "rights_review"]},
        "checklist_version": {"type": "string"},
        "outcome": {"enum": ["approve", "changes_required", "disputed"]},
        "limitations": {"type": "array", "items": {"type": "string"}},
        "conflict_declaration": {"type": "string"},
        "date": {"type": "string", "format": "date"},
        "commit_hash": {"type": ["string", "null"]}
      }
    }
  }
}
